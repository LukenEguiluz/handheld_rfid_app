<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.DoHealth.Card.ListItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_medium"
    android:layout_marginBottom="@dimen/gutter">

    <LinearLayout
        android:id="@+id/cardRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/productCodeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.DoHealth.CardTitle.Dark"
                    tools:text="SKU-001" />

                <TextView
                    android:id="@+id/productDescText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_xsmall"
                    android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary"
                    tools:text="Descripción del producto" />
            </LinearLayout>

            <TextView
                android:id="@+id/statusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_small"
                android:background="@drawable/bg_chip_status_pending"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/status_pending"
                android:textAppearance="@style/TextAppearance.DoHealth.Chip" />

            <ImageButton
                android:id="@+id/expandButton"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:layout_marginStart="@dimen/margin_xsmall"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/esferica_expand_detail"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:orientation="horizontal"
            android:weightSum="4">

            <TextView
                android:id="@+id/countExpected"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.DoHealth.Label"
                tools:text="Esp.\n10" />

            <TextView
                android:id="@+id/countRead"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.DoHealth.Label"
                tools:text="Leíd.\n8" />

            <TextView
                android:id="@+id/countMissing"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.DoHealth.Label"
                tools:text="Falt.\n2" />

            <TextView
                android:id="@+id/countExtra"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.DoHealth.Label"
                tools:text="Sobr.\n0" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/detailSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/esferica_missing_rfids"
                android:textAppearance="@style/TextAppearance.DoHealth.Label" />

            <TextView
                android:id="@+id/missingRfidsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_xsmall"
                android:fontFamily="monospace"
                android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary"
                android:textIsSelectable="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:text="@string/esferica_read_rfids"
                android:textAppearance="@style/TextAppearance.DoHealth.Label" />

            <TextView
                android:id="@+id/readRfidsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_xsmall"
                android:fontFamily="monospace"
                android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary"
                android:textIsSelectable="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:text="@string/esferica_extra_rfids_section"
                android:textAppearance="@style/TextAppearance.DoHealth.Label" />

            <TextView
                android:id="@+id/extraRfidsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_xsmall"
                android:fontFamily="monospace"
                android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary"
                android:textIsSelectable="true" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
