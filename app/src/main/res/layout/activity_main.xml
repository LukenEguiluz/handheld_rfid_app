<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.DoHealthHandheld.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            style="@style/Widget.DoHealth.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_medium">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_device_info_card"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/module_icon_size"
                            android:layout_height="@dimen/module_icon_size"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_antenna" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_small"
                            android:text="@string/device_info_title"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardTitle" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/device_label"
                            android:textAppearance="@style/TextAppearance.DoHealth.Label"
                            android:textColor="@color/text_on_secondary_muted" />

                        <TextView
                            android:id="@+id/deviceNameText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.DoHealth.KpiValue"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_xsmall"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/device_address_label"
                            android:textAppearance="@style/TextAppearance.DoHealth.Label"
                            android:textColor="@color/text_on_secondary_muted" />

                        <TextView
                            android:id="@+id/deviceAddressText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textAppearance="@style/TextAppearance.DoHealth.KpiValue"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_size_small" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <include
                android:id="@+id/modeSectionHeader"
                layout="@layout/include_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/gutter" />

            <!-- RFID -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/rfidCard"
                style="@style/Widget.DoHealth.Card.Module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/gutter">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_module_card">

                    <FrameLayout
                        android:layout_width="@dimen/module_icon_container_size"
                        android:layout_height="@dimen/module_icon_container_size"
                        android:background="@drawable/bg_module_icon">

                        <ImageView
                            android:layout_width="@dimen/module_icon_size"
                            android:layout_height="@dimen/module_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_nfc" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_rfid"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardTitle" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_xsmall"
                            android:text="@string/mode_rfid_description"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.5"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Lectura Continua -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/continuousCard"
                style="@style/Widget.DoHealth.Card.Module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/gutter">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_module_card">

                    <FrameLayout
                        android:layout_width="@dimen/module_icon_container_size"
                        android:layout_height="@dimen/module_icon_container_size"
                        android:background="@drawable/bg_module_icon">

                        <ImageView
                            android:layout_width="@dimen/module_icon_size"
                            android:layout_height="@dimen/module_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_antenna" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_continuous"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardTitle" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_xsmall"
                            android:text="@string/mode_continuous_description"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.5"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Barcode -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/barcodeCard"
                style="@style/Widget.DoHealth.Card.Module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/gutter">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_module_card">

                    <FrameLayout
                        android:layout_width="@dimen/module_icon_container_size"
                        android:layout_height="@dimen/module_icon_container_size"
                        android:background="@drawable/bg_module_icon">

                        <ImageView
                            android:layout_width="@dimen/module_icon_size"
                            android:layout_height="@dimen/module_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_barcode" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_barcode"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardTitle" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_xsmall"
                            android:text="@string/mode_barcode_description"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.5"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ESFERICA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/esfericaCard"
                style="@style/Widget.DoHealth.Card.Module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/gutter">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_module_card">

                    <FrameLayout
                        android:layout_width="@dimen/module_icon_container_size"
                        android:layout_height="@dimen/module_icon_container_size"
                        android:background="@drawable/bg_module_icon">

                        <ImageView
                            android:layout_width="@dimen/module_icon_size"
                            android:layout_height="@dimen/module_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_esferica" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_esferica"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardTitle" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_xsmall"
                            android:text="@string/mode_esferica_description"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.5"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- HGM -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/hgmCard"
                style="@style/Widget.DoHealth.Card.Module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/gutter">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_module_card">

                    <FrameLayout
                        android:layout_width="@dimen/module_icon_container_size"
                        android:layout_height="@dimen/module_icon_container_size"
                        android:background="@drawable/bg_module_icon">

                        <ImageView
                            android:layout_width="@dimen/module_icon_size"
                            android:layout_height="@dimen/module_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_blood" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_hgm"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardTitle" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_xsmall"
                            android:text="@string/mode_hgm_description"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.5"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Relación -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/relacionCodigosCard"
                style="@style/Widget.DoHealth.Card.Module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/gutter">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_module_card">

                    <FrameLayout
                        android:layout_width="@dimen/module_icon_container_size"
                        android:layout_height="@dimen/module_icon_container_size"
                        android:background="@drawable/bg_module_icon">

                        <ImageView
                            android:layout_width="@dimen/module_icon_size"
                            android:layout_height="@dimen/module_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_link" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/module_relacion_codigos"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardTitle" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_xsmall"
                            android:text="@string/module_relacion_codigos_description"
                            android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.5"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/configButton"
                style="@style/Widget.DoHealth.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/margin_medium"
                android:text="@string/settings" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
