<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.DoHealth.Card.ListItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_medium"
    android:layout_marginBottom="@dimen/gutter">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <TextView
            android:id="@+id/offCatalogSkuText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.DoHealth.CardTitle.Dark"
            tools:text="SKU-12345" />

        <TextView
            android:id="@+id/offCatalogRfidText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_xsmall"
            android:fontFamily="monospace"
            android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary"
            tools:text="E20000112233445566778899" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
