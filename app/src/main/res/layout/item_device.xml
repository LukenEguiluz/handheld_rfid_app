<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.DoHealth.Card.Module"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/gutter"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/primary_gray"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:rippleColor="@color/primary_red_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="@dimen/touch_target_min"
        android:orientation="horizontal"
        android:padding="@dimen/padding_medium">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/deviceNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dispositivo"
                android:textAppearance="@style/TextAppearance.DoHealth.CardTitle" />

            <TextView
                android:id="@+id/deviceAddressText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_xsmall"
                android:fontFamily="monospace"
                android:text="00:00:00:00:00:00"
                android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:alpha="0.5"
            android:contentDescription="@null"
            android:src="@drawable/ic_chevron_right" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
