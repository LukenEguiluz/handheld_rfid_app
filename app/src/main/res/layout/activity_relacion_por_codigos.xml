<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.DoHealthHandheld.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            style="@style/Widget.DoHealth.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:popupTheme="@style/Theme.DoHealthHandheld.PopupOverlay" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.DoHealth.Card.Module"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_medium">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_medium">

                <TextView
                    android:id="@+id/sessionNameText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lectura"
                    android:textAppearance="@style/TextAppearance.DoHealth.CardTitle" />

                <TextView
                    android:id="@+id/stepText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:alpha="0.95"
                    android:text="@string/relacion_step_product"
                    android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:alpha="0.9"
                    android:text="@string/relacion_second_read_mode"
                    android:textAppearance="@style/TextAppearance.DoHealth.Label"
                    android:textColor="@color/text_on_secondary_muted" />

                <RadioGroup
                    android:id="@+id/secondReadModeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioSecondRfid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/white"
                        android:text="@string/relacion_second_read_rfid"
                        android:textColor="@color/white" />

                    <RadioButton
                        android:id="@+id/radioSecondBarcode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:buttonTint="@color/white"
                        android:text="@string/relacion_second_read_barcode"
                        android:textColor="@color/white" />
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/relationsCountText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/relacion_relations_count"
                        android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/keepProductSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/relacion_keep_product"
                        android:textColor="@color/white" />
                </LinearLayout>

                <TextView
                    android:id="@+id/currentProductLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:text="@string/relacion_current_product"
                    android:textAppearance="@style/TextAppearance.DoHealth.CardSubtitle"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/currentProductValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_xsmall"
                    android:fontFamily="monospace"
                    android:text="---"
                    android:textAppearance="@style/TextAppearance.DoHealth.CardTitle"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clearProductButton"
                    style="@style/Widget.DoHealth.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:text="@string/relacion_clear_product"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_medium"
            android:layout_marginBottom="@dimen/margin_small"
            android:text="@string/relacion_list_section"
            android:textAppearance="@style/TextAppearance.DoHealth.Label" />

        <TextView
            android:id="@+id/emptyListText"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="@dimen/padding_large"
            android:text="@string/relacion_empty_list"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_medium"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/relationsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/background_light"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/padding_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/exportTxtButton"
            style="@style/Widget.DoHealth.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_medium"
            android:layout_marginTop="@dimen/margin_small"
            android:text="@string/relacion_export_txt" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startStopButton"
            style="@style/Widget.DoHealth.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginHorizontal="@dimen/margin_medium"
            android:layout_marginTop="@dimen/margin_small"
            android:layout_marginBottom="@dimen/margin_medium"
            android:text="@string/relacion_start" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
