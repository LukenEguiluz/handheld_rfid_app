<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.DoHealthHandheld.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_red"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:popupTheme="@style/Theme.DoHealthHandheld.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_medium"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/primary_gray">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_medium">

                <TextView
                    android:id="@+id/sessionNameText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lectura"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/stepText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/relacion_step_product"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_medium"
                    android:alpha="0.95"
                    android:layout_marginTop="@dimen/margin_small" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/relacion_second_read_mode"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_small"
                    android:alpha="0.9"
                    android:layout_marginTop="@dimen/margin_medium" />

                <RadioGroup
                    android:id="@+id/secondReadModeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/margin_small">

                    <RadioButton
                        android:id="@+id/radioSecondRfid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/relacion_second_read_rfid"
                        android:textColor="@color/white"
                        android:buttonTint="@color/white" />

                    <RadioButton
                        android:id="@+id/radioSecondBarcode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_medium"
                        android:text="@string/relacion_second_read_barcode"
                        android:textColor="@color/white"
                        android:buttonTint="@color/white" />
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/relationsCountText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/relacion_relations_count"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_medium" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/keepProductSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/relacion_keep_product"
                        android:textColor="@color/white" />
                </LinearLayout>

                <TextView
                    android:id="@+id/currentProductLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/relacion_current_product"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_medium"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/currentProductValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_medium"
                    android:fontFamily="monospace"
                    android:layout_marginTop="@dimen/margin_small"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clearProductButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/relacion_clear_product"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_red"
                    android:layout_marginTop="@dimen/margin_small"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/emptyListText"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="No hay relaciones todavía.\nInicia la lectura para comenzar."
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_medium"
            android:gravity="center"
            android:padding="@dimen/padding_large"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/relationsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/white"
            android:clipToPadding="false"
            android:paddingTop="@dimen/padding_small"
            android:paddingBottom="@dimen/padding_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/exportTxtButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/relacion_export_txt"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary_gray"
            android:layout_marginHorizontal="@dimen/margin_small"
            android:layout_marginTop="@dimen/margin_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startStopButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/relacion_start"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary_red"
            android:layout_marginHorizontal="@dimen/margin_small"
            android:layout_marginTop="@dimen/margin_small"
            android:layout_marginBottom="@dimen/margin_small" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

