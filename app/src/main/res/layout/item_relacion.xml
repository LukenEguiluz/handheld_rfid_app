<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.DoHealth.Card.ListItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_medium"
    android:layout_marginBottom="@dimen/gutter"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/positionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="40dp"
                android:textAppearance="@style/TextAppearance.DoHealth.KpiValue"
                android:textColor="@color/primary_red"
                tools:text="#1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_xsmall"
                android:text="Producto:"
                android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary" />

            <TextView
                android:id="@+id/productText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_xsmall"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textAppearance="@style/TextAppearance.DoHealth.CardTitle.Dark"
                android:textSize="@dimen/text_size_medium"
                tools:text="PROD-123" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/secondCodeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="40dp"
                android:text="@string/relacion_item_second_rfid"
                android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary" />

            <TextView
                android:id="@+id/rfidText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_xsmall"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textAppearance="@style/TextAppearance.DoHealth.CardTitle.Dark"
                android:textSize="@dimen/text_size_medium"
                tools:text="E20000112233445566778899" />

            <TextView
                android:id="@+id/timeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_small"
                android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary"
                tools:text="12:00:00" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
