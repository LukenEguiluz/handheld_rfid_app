<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.DoHealthHandheld.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            style="@style/Widget.DoHealth.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:popupTheme="@style/Theme.DoHealthHandheld.PopupOverlay" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_medium">

            <include layout="@layout/include_config_section_power" />

            <!-- Potencia RF -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/power_level"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/powerInfoIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="@null"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_info" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/powerSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_spinner_outlined"
                        android:paddingHorizontal="@dimen/padding_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Valor Q -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/q_value"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/qValueInfoIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="@null"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_info" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/qValueSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_spinner_outlined"
                        android:paddingHorizontal="@dimen/padding_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sesión -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/session"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/sessionInfoIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="@null"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_info" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/sessionSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_spinner_outlined"
                        android:paddingHorizontal="@dimen/padding_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Antena -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/antenna"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/antennaInfoIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="@null"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_info" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/antennaSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_spinner_outlined"
                        android:paddingHorizontal="@dimen/padding_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <include layout="@layout/include_config_section_timing" />

            <!-- Tiempo de Filtro -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tiempo de Filtro (s)"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/filterTimeInfoIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="@null"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_info" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/filterTimeSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_spinner_outlined"
                        android:paddingHorizontal="@dimen/padding_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tiempo de Buzzer -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tiempo de Buzzer (10ms)"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/buzzerTimeInfoIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="@null"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_info" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/buzzerTimeSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_spinner_outlined"
                        android:paddingHorizontal="@dimen/padding_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Intervalo de Polling -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Intervalo de Polling (10ms)"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/pollingIntervalInfoIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="@null"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_info" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/pollingIntervalSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_spinner_outlined"
                        android:paddingHorizontal="@dimen/padding_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <include layout="@layout/include_config_section_modes" />

            <!-- Modo de Trabajo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Modo de Trabajo"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/workModeInfoIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="@null"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_info" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/workModeSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_spinner_outlined"
                        android:paddingHorizontal="@dimen/padding_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Área de Consulta -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Área de Consulta"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/inquiryAreaInfoIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="@null"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_info" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/inquiryAreaSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_spinner_outlined"
                        android:paddingHorizontal="@dimen/padding_small" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/webhookConfigButton"
                style="@style/Widget.DoHealth.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/margin_medium"
                android:text="@string/continuous_webhook_settings_button" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/background_light"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/margin_medium"
        android:paddingVertical="@dimen/margin_small">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/loadButton"
            style="@style/Widget.DoHealth.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_marginEnd="@dimen/gutter"
            android:layout_weight="1"
            android:text="@string/load_config" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            style="@style/Widget.DoHealth.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/save_config" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
