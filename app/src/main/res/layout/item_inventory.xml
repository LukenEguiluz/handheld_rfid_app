<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.DoHealth.Card.ListItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/margin_medium"
    android:layout_marginBottom="@dimen/gutter"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="@dimen/padding_medium">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/positionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="40dp"
                android:textAppearance="@style/TextAppearance.DoHealth.KpiValue"
                android:textColor="@color/primary_red"
                tools:text="#1" />

            <TextView
                android:id="@+id/dataText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginEnd="@dimen/margin_small"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textAppearance="@style/TextAppearance.DoHealth.CardTitle.Dark"
                android:textSize="@dimen/text_size_medium"
                tools:text="E20000112233445566778899" />

            <TextView
                android:id="@+id/repeatCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_status_active"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textAppearance="@style/TextAppearance.DoHealth.Chip"
                android:visibility="gone"
                tools:text="×2"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/modeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_status_pending"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="RFID"
                android:textAppearance="@style/TextAppearance.DoHealth.Chip"
                tools:text="RFID" />

            <TextView
                android:id="@+id/rssiText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary"
                android:visibility="gone"
                tools:text="RSSI: -50 dBm"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/timeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.DoHealth.BodySecondary"
                tools:text="12:00:00" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
