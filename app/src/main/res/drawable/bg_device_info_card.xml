<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_gray" />
            <corners android:radius="@dimen/card_corner_radius" />
        </shape>
    </item>
    <item android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_red" />
            <size android:width="@dimen/device_card_accent_width" />
            <corners
                android:topLeftRadius="@dimen/card_corner_radius"
                android:bottomLeftRadius="@dimen/card_corner_radius" />
        </shape>
    </item>
</layer-list>
