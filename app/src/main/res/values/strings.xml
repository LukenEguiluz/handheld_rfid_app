    <!-- Descripciones de configuración -->
    <string name="power_level_desc">Controla la potencia de salida del transmisor RFID. Mayor potencia = mayor rango de lectura, pero más consumo de batería. Rango: 0-33 dBm</string>
    <string name="q_value_desc">Valor inicial Q para el algoritmo de anti-colisión. Q ≈ log2(cantidad de tags). Q=4 para ~16 tags, Q=7 para ~128 tags. Rango: 0-15</string>
    <string name="session_desc">Sesión RFID a usar para el inventario. 0=S0, 1=S1, 2=S2, 3=S3. Rango: 0-3</string>
    <string name="antenna_desc">Selección de antenas activas (bitmask). 1=Antena 1, 2=Antena 2, 3=Antenas 1 y 2, etc.</string>
    <string name="filter_time_desc">Tiempo durante el cual se filtran tags duplicados después de una lectura exitosa. 0=sin filtro. Rango: 0-255 segundos</string>
    <string name="buzzer_time_desc">Duración del sonido del buzzer al completar operación. Unidad: 10ms. 0=sin sonido. Rango: 0-255</string>
    <string name="polling_interval_desc">Intervalo entre consultas de inventario. Unidad: 10ms. Rango: 0-255</string>
    <string name="work_mode_desc">Modo de operación: 0=Respuesta (espera comandos), 1=Activo (envía datos automáticamente), 2=Trigger (controlado por gatillo)</string>
    <string name="inquiry_area_desc">Área de memoria del tag a consultar: EPC, TID, USER o combinaciones</string>
    
