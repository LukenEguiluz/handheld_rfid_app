<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DoHealthHandheld" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_red</item>
        <item name="colorPrimaryDark">@color/primary_red_dark</item>
        <item name="colorPrimaryVariant">@color/primary_red_dark</item>
        <item name="colorSecondary">@color/primary_gray</item>
        <item name="colorAccent">@color/primary_red</item>
        <item name="colorSurface">@color/background_white</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/primary_red_dark</item>
        <item name="android:navigationBarColor">@color/background_light</item>
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="android:colorBackgroundFloating">@color/color_background_floating_dark</item>
        <item name="popupMenuStyle">@style/Widget.DoHealth.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.DoHealth.PopupMenu</item>
        <item name="materialButtonStyle">@style/Widget.DoHealth.Button.Primary</item>
        <item name="materialCardViewStyle">@style/Widget.DoHealth.Card</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.DoHealth.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.DoHealth.Medium</item>
    </style>

    <style name="Theme.DoHealthHandheld.Splash" parent="Theme.DoHealthHandheld">
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:navigationBarColor">@color/background_light</item>
    </style>

    <style name="Theme.DoHealthHandheld.Esferica" parent="Theme.DoHealthHandheld" />

    <style name="Theme.DoHealthHandheld.Hgm" parent="Theme.DoHealthHandheld.Esferica" />

    <style name="ShapeAppearance.DoHealth.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.DoHealth.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">@dimen/card_corner_radius</item>
    </style>

    <style name="ShapeAppearance.DoHealth.Dialog" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">@dimen/dialog_corner_radius</item>
    </style>
</resources>
